{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "kopling/development",
    "type": "project",
    "description": "The development environment for the Kopling community software.",
    "keywords": [
        "kopling",
        "community"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Daniël Klabbers",
            "email": "daniel@klabbers.email"
        }
    ],
    "funding": [
        {
            "type": "opencollective",
            "url": "https://opencollective.com/kopling"
        }
    ],
    "require": {
        "kopling/admin": "@dev",
        "kopling/auth-email-password": "@dev",
        "kopling/composer": "@dev",
        "kopling/core": "@dev",
        "kopling/demo": "@dev",
        "kopling/discussions": "@dev",
        "kopling/docs": "@dev",
        "kopling/example": "@dev",
        "kopling/pages": "@dev",
        "kopling/pin": "@dev",
        "kopling/poll": "@dev",
        "kopling/reactions": "@dev",
        "kopling/reply-dock": "@dev",
        "kopling/style-guide": "@dev",
        "kopling/tags": "@dev",
        "kopling/theme-delft": "@dev",
        "kopling/theme-midnight": "@dev",
        "kopling/thread-title": "@dev",
        "kopling/widgets": "@dev"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php -r \"is_dir('database') || mkdir('database', 0755, true); file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan package:discover --ansi",
            "@php artisan kopling:extensions:discover --ansi"
        ],
        "demo": [
            "@php artisan kopling:extensions:disable kopling/example --ansi",
            "@php artisan kopling:demo:seed-admin --ansi",
            "@php artisan kopling:demo:seed-fake-data --ansi",
            "@php artisan kopling:reactions:seed-demo --ansi",
            "@php artisan kopling:discussions:seed-demo --ansi",
            "@php artisan kopling:tags:seed-demo --ansi"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": {
        "core": {
            "type": "path",
            "url": "./k-core"
        },
        "extensions": {
            "type": "path",
            "url": "./k-extensions/*"
        }
    },
    "require-dev": {
        "laravel/tinker": "^3.0",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    }
}
