{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "kopling/development",
    "type": "project",
    "description": "The development environment for the Kopling community software.",
    "keywords": ["kopling", "community"],
    "license": "MIT",
    "authors": [
        {
            "name": "Daniël Klabbers",
            "email": "daniel@klabbers.email"
        }
    ],
    "require": {
        "kopling/admin": "@dev",
        "kopling/auth-password": "@dev",
        "kopling/core": "@dev",
        "kopling/demo": "@dev",
        "kopling/example": "@dev",
        "kopling/reactions": "@dev",
        "kopling/theme-midnight": "@dev"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php -r \"is_dir('database') || mkdir('database', 0755, true); file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan package:discover --ansi",
            "@php artisan kopling:extensions:discover --ansi"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": {
        "core": {
            "type": "path",
            "url": "./k-core"
        },
        "extensions": {
            "type": "path",
            "url": "./k-extensions/*"
        }
    },
    "require-dev": {
        "laravel/tinker": "^3.0"
    }
}
