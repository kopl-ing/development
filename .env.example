APP_NAME=Kopling
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log

# Optional -- raises Font Awesome's anonymous GraphQL API rate limit for Ux\Form\IconPicker's
# icon search. Icon search works without one; get a token at fontawesome.com/account/general.
FONT_AWESOME_API_TOKEN=
